# PulseBrief local environment example.
# Copy to .env.local for local experiments. Do not commit .env.local.

# Core services
PULSEBRIEF_DB_URL=jdbc:mysql://localhost:3307/pulsebrief?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
PULSEBRIEF_DB_USERNAME=pulsebrief
PULSEBRIEF_DB_PASSWORD=pulsebrief_dev
PULSEBRIEF_ADMIN_LEGACY_TOKEN_ENABLED=false
PULSEBRIEF_ADMIN_LEGACY_TOKEN=
PULSEBRIEF_ADMIN_SESSION_HOURS=12
PULSEBRIEF_ADMIN_MAX_FAILED_ATTEMPTS=5
PULSEBRIEF_ADMIN_LOCK_MINUTES=15
PULSEBRIEF_ADMIN_PASSWORD_MAX_AGE_DAYS=90
PULSEBRIEF_ADMIN_SESSION_CLEANUP_RETENTION_DAYS=7
PULSEBRIEF_ADMIN_SESSION_CLEANUP_ENABLED=true
PULSEBRIEF_ADMIN_SESSION_CLEANUP_CRON=0 15 3 * * *
# One-time bootstrap. Remove the password from the runtime environment after the account exists.
PULSEBRIEF_ADMIN_BOOTSTRAP_USERNAME=
PULSEBRIEF_ADMIN_BOOTSTRAP_PASSWORD=
PULSEBRIEF_ADMIN_BOOTSTRAP_DISPLAY_NAME=PulseBrief Admin
PULSEBRIEF_ADMIN_BOOTSTRAP_ROLE=ADMIN

# Ingestion is disabled by default. Keep CI and normal local development safe.
PULSEBRIEF_INGESTION_ENABLED=false

# Set only when explicitly testing a real provider.
# Allowed values: FIXTURE, RSS, API
PULSEBRIEF_PROVIDER_KIND=

# RSS provider inputs. Use comma-separated HTTPS RSS feed URLs.
PULSEBRIEF_RSS_FEED_URLS=

# API provider inputs. Never commit a real API key.
PULSEBRIEF_PROVIDER_API_BASE_URL=
PULSEBRIEF_PROVIDER_API_KEY=

# Compliance and freshness guardrails.
# Allowed policy values: SUMMARY_ONLY, SNIPPET_ALLOWED, FULLTEXT_ALLOWED, PDF_ALLOWED, LINK_ONLY, UNKNOWN
PULSEBRIEF_PROVIDER_LICENSE_POLICY=SUMMARY_ONLY
PULSEBRIEF_PROVIDER_LICENSE_NOTE=
PULSEBRIEF_INGESTION_MAX_AGE_HOURS=24
PULSEBRIEF_INGESTION_PDF_MAX_AGE_HOURS=72
PULSEBRIEF_INGESTION_MAX_ITEMS_PER_SOURCE=50
PULSEBRIEF_PROVIDER_RATE_LIMIT_PER_HOUR=60
PULSEBRIEF_INGESTION_ALLOW_BACKFILL=false
PULSEBRIEF_INGESTION_ALLOW_FULL_TEXT=false
PULSEBRIEF_INGESTION_ALLOW_PDF_DOWNLOAD=false

# AI summary provider. Disabled by default; never commit a real API key.
PULSEBRIEF_DEEPSEEK_ENABLED=false
PULSEBRIEF_DEEPSEEK_API_KEY=
PULSEBRIEF_DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
PULSEBRIEF_DEEPSEEK_MODEL=deepseek-v4-flash
PULSEBRIEF_DEEPSEEK_TIMEOUT_SECONDS=30
PULSEBRIEF_DEEPSEEK_MAX_INPUT_CHARACTERS=12000
PULSEBRIEF_DEEPSEEK_MAX_OUTPUT_TOKENS=1200
PULSEBRIEF_DEEPSEEK_CLASSIFICATION_ENABLED=false
PULSEBRIEF_DEEPSEEK_CLASSIFICATION_MIN_CONFIDENCE=0.65
PULSEBRIEF_DEEPSEEK_CLASSIFICATION_MAX_INPUT_CHARACTERS=4000
PULSEBRIEF_DEEPSEEK_CLASSIFICATION_MAX_OUTPUT_TOKENS=300
PULSEBRIEF_AI_USAGE_ENABLED=true
PULSEBRIEF_AI_DAILY_REQUEST_LIMIT=200
PULSEBRIEF_AI_DAILY_TOKEN_LIMIT=200000
PULSEBRIEF_AI_WARNING_PERCENT=80
# Set these from the current provider pricing contract; defaults avoid stale hard-coded prices.
PULSEBRIEF_AI_DEEPSEEK_INPUT_COST_PER_MILLION_USD=0
PULSEBRIEF_AI_DEEPSEEK_OUTPUT_COST_PER_MILLION_USD=0

# Optional OpenAI fallback.
PULSEBRIEF_OPENAI_ENABLED=false
PULSEBRIEF_OPENAI_API_KEY=
PULSEBRIEF_OPENAI_BASE_URL=https://api.openai.com/v1/responses
PULSEBRIEF_OPENAI_MODEL=gpt-5.6-luna
PULSEBRIEF_OPENAI_TIMEOUT_SECONDS=30
PULSEBRIEF_OPENAI_MAX_INPUT_CHARACTERS=12000
PULSEBRIEF_OPENAI_MAX_OUTPUT_TOKENS=1200
